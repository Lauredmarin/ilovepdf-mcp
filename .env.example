# iLovePDF API Credentials
# Get your keys from https://developer.ilovepdf.com/user/projects
ILOVEPDF_PUBLIC_KEY=your_public_key_here
ILOVEPDF_SECRET_KEY=your_secret_key_here

# Default output directory for processed files (optional)
# If not set, files will be saved to ./output
DEFAULT_OUTPUT_DIR=./output
